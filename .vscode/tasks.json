{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build pokeafterglow debug",
      "type": "shell",
      "command": "make",
      "args": [
        "DEBUG=1",
        "crystal_debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "build pokeafterglow",
      "type": "shell",
      "command": "make",
      "args": [
        "DEBUG=1",
        "crystal"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "clean pokeafterglow",
      "type": "shell",
      "command": "make",
      "args": [
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
